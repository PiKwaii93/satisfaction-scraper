# Local development defaults.
# Copy to .env only if you want to override docker-compose values.

DB_HOST=postgres_db
DB_NAME=satisfaction_client
DB_USER=admin
DB_PASSWORD=password123

MLFLOW_TRACKING_URI=http://mlflow:5000
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Legacy internal API key. The frontend uses JWT Bearer tokens.
API_KEY=dev-satisfaction-key

# Replace before any non-local deployment.
JWT_SECRET_KEY=change-me-with-a-long-random-secret
JWT_EXPIRE_MINUTES=1440

DEMO_ORG_NAME=Demo Satisfaction Client
DEMO_ORG_SLUG=demo
DEMO_ADMIN_EMAIL=demo@satisfaction.local
DEMO_ADMIN_PASSWORD=demo-password
DEMO_ADMIN_NAME=Admin Demo

PLATFORM_ORG_NAME=Plateforme Satisfaction
PLATFORM_ORG_SLUG=platform
PLATFORM_ADMIN_EMAIL=platform@satisfaction.local
PLATFORM_ADMIN_PASSWORD=platform-password
PLATFORM_ADMIN_NAME=Admin Plateforme

INVITATION_EXPIRE_DAYS=7
FRONTEND_BASE_URL=http://localhost:5173
FEEDBACK_SAMPLE_WEIGHT=6

# Frontend
VITE_API_BASE_URL=http://localhost:8000
